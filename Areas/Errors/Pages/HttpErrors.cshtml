@*
	Component of the Ans.Net8.Web library.
	Not intended for editing and runtime compilation!!
*@
@page
@model Ans.Net8.Web.Areas.Errors.Pages.HttpErrorsModel
@{
	switch (Model.HttpCode)
	{
		case 403:
			<partial name="_http403" />
			break;
		case 404:
			<partial name="_http404" />
			break;
		default:
			<partial name="_http400" />
			break;
	}
}
